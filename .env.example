# ════════════════════════════════════════════════════════════════════════════
# frdcmp-infra — combined environment
# Copy to .env and fill in real secrets:  cp .env.example .env
#
# One .env for the whole stack (clickhouse + valkey + prometheus + grafana).
# ════════════════════════════════════════════════════════════════════════════

# ── ClickHouse: bootstrap admin user ─────────────────────────────────────────
# Used by the init script to create tenant databases/users, and for the
# healthcheck. Has access management. Keep these secret.
CLICKHOUSE_ADMIN_USER="admin"
CLICKHOUSE_ADMIN_PASSWORD="change-me-admin-password"

# ── ClickHouse: external exposure ────────────────────────────────────────────
# A single high port for the HTTP endpoint (mapped to container 8123).
CLICKHOUSE_EXT_PORT="46003"
# Interface to bind the published port to. Default 127.0.0.1 (localhost-only).
# In production set this to the host's private-overlay IP (e.g. the private overlay) so
# stacks on OTHER hosts can reach it:  CLICKHOUSE_BIND="<your-overlay-ip>"
CLICKHOUSE_BIND="127.0.0.1"

# ── ClickHouse: resources ────────────────────────────────────────────────────
CLICKHOUSE_MEM_LIMIT="2g"
CLICKHOUSE_CPUS="2"

# ── ClickHouse: tenants (databases + users) ──────────────────────────────────
# Space-separated  db:user:password  triples. One per project. Provisioned on
# first boot only (empty ./clickhouse/clickhouse_data). To add a tenant later,
# see README.
#   app_one   → MTG e-commerce (log_worker: page_visits, db_writes, …)
#   app_two  → app_two stack
CH_TENANTS="app_one:app_one:change-me-app_one-password app_two:app_two:change-me-app_two-password"

# ── Valkey: bootstrap admin (the `default` ACL user; full access) ─────────────
# Used by the healthcheck and for ops/migration. Keep secret.
VK_ADMIN_PASSWORD="change-me-admin-password"

# ── Valkey: external exposure ────────────────────────────────────────────────
# A single high port for the Valkey endpoint (mapped to container 6379).
VK_EXT_PORT="46004"
# Interface to bind the published port to. Default 127.0.0.1 (localhost-only).
# In production set this to the host's private-overlay IP (e.g. the private overlay) so
# stacks on OTHER hosts can reach it:  VK_BIND="<your-overlay-ip>"
VK_BIND="127.0.0.1"

# ── Valkey: resources ────────────────────────────────────────────────────────
VK_MEM_LIMIT="1g"
VK_MAXMEMORY="768mb"      # keep below VK_MEM_LIMIT; noeviction policy
VK_CPUS="1"

# ── Valkey: tenants (name:password) ──────────────────────────────────────────
# Space-separated  name:password  pairs. One per service. `name` is BOTH the
# ACL username AND the mandatory key/channel prefix (service locked to
# ~name:* keys and &name:* channels). Add a pair here to onboard a service.
#   app_one   → MTG e-commerce
#   app_two  → app_two stack
VK_TENANTS="app_one:change-me-app_one-password app_two:change-me-app_two-password"

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD="change-me-grafana-password"
# Public root URL Grafana advertises (links, redirects). Set to however this
# host is reached — e.g. its the private overlay IP and published port:
#   GRAFANA_ROOT_URL="http://<your-overlay-ip>:3001"
GRAFANA_ROOT_URL="http://127.0.0.1:3001"

# ── Published host ports (left of the colon in docker-compose) ────────────────
GRAFANA_EXT_PORT="3001"
PROMETHEUS_EXT_PORT="9090"
