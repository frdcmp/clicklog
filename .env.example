# ════════════════════════════════════════════════════════════════════════════
# clicklog — environment
# Copy to .env and fill in real secrets:  cp .env.example .env
#
# Only the gateway (and the optional dashboard) are configurable here.
# ClickHouse and Valkey need nothing: no ports, no credentials — they live on
# the internal `clicklog` network, reachable only by ingest-api.
# ════════════════════════════════════════════════════════════════════════════

# ── Ingest API: exposure ─────────────────────────────────────────────────────
# Interface the published port binds to. Default 127.0.0.1 (local only). In
# production set the host's private-overlay IP (e.g. the private overlay) so apps on
# other hosts can POST events. NEVER a public NIC.
INGEST_BIND="127.0.0.1"
INGEST_EXT_PORT="46005"
INGEST_RUST_LOG="info"

# ── Admin dashboard: auth (JWT + single seeded admin) ────────────────────────
# Login at POST /v1/admin/login with ADMIN_EMAIL/ADMIN_PASSWORD returns an
# HS256 JWT signed with JWT_SECRET (generate: `openssl rand -hex 32`).
# Empty JWT_SECRET disables login and all admin endpoints.
JWT_SECRET="change-me-with-openssl-rand-hex-32"
JWT_TTL_HOURS="24"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-admin-password"

# ── Admin dashboard: exposure (optional; --profile dashboard) ────────────────
# Same rule as INGEST_BIND: overlay IP in production, never a public NIC.
FRONTEND_BIND="127.0.0.1"
FRONTEND_EXT_PORT="46006"

# ── Resources ────────────────────────────────────────────────────────────────
CLICKHOUSE_MEM_LIMIT="2g"
CLICKHOUSE_CPUS="2"
VK_MEM_LIMIT="1g"
VK_MAXMEMORY="768mb"      # keep below VK_MEM_LIMIT; noeviction policy
VK_CPUS="1"
