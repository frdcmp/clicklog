# ════════════════════════════════════════════════════════════════════════════
# frdcmp-infra — combined environment
# Copy to .env and fill in real secrets:  cp .env.example .env
#
# One .env for the whole stack (clickhouse + valkey + ingest-api).
# ════════════════════════════════════════════════════════════════════════════

# ── ClickHouse: bootstrap admin user ─────────────────────────────────────────
# Used by the init script to create tenant databases/users, and for the
# healthcheck. Has access management. Keep these secret.
CLICKHOUSE_ADMIN_USER="admin"
CLICKHOUSE_ADMIN_PASSWORD="change-me-admin-password"

# ── ClickHouse: external exposure — DISABLED ─────────────────────────────────
# ClickHouse is NO LONGER published on the host. It is reachable only on the
# internal `frdcmp` network (clickhouse:8123), in practice only by ingest-api.
# ALL event data must enter through the ingest-api gateway — there is no direct
# write path and no fallback. (These vars are kept for reference only and are
# not used by docker-compose.yml anymore.)
# CLICKHOUSE_EXT_PORT="46003"
# CLICKHOUSE_BIND="127.0.0.1"

# ── ClickHouse: resources ────────────────────────────────────────────────────
CLICKHOUSE_MEM_LIMIT="2g"
CLICKHOUSE_CPUS="2"

# ── ClickHouse: tenants — normally EMPTY ─────────────────────────────────────
# The ingest-api gateway writes as the admin user and creates each project's
# database + `events` table on demand. Projects do NOT get their own ClickHouse
# user (that was the direct-write bypass; it has been removed). Leave this empty.
#
# Only set it (space-separated db:user:password triples) if you deliberately want
# a restricted ClickHouse user for ad-hoc READ queries against a database — note
# the init script grants FULL access on that db, so adjust grants by hand if you
# only want reads. Provisioned on first boot only (empty ./clickhouse_data).
CH_TENANTS=""

# ── Valkey: bootstrap admin (the `default` ACL user; full access) ─────────────
# Used by the healthcheck and for ops/migration. Keep secret.
VK_ADMIN_PASSWORD="change-me-admin-password"

# ── Valkey: external exposure ────────────────────────────────────────────────
# A single high port for the Valkey endpoint (mapped to container 6379).
VK_EXT_PORT="46004"
# Interface to bind the published port to. Default 127.0.0.1 (localhost-only).
# In production set this to the host's private-overlay IP (e.g. the private overlay) so
# stacks on OTHER hosts can reach it:  VK_BIND="<your-overlay-ip>"
VK_BIND="127.0.0.1"

# ── Valkey: resources ────────────────────────────────────────────────────────
VK_MEM_LIMIT="1g"
VK_MAXMEMORY="768mb"      # keep below VK_MEM_LIMIT; noeviction policy
VK_CPUS="1"

# ── Valkey: tenants (name:password) ──────────────────────────────────────────
# Space-separated  name:password  pairs. One per service. `name` is BOTH the
# ACL username AND the mandatory key/channel prefix (service locked to
# ~name:* keys and &name:* channels). Add a pair here to onboard a service.
#   app_one   → MTG e-commerce
#   app_two  → app_two stack
VK_TENANTS="app_one:change-me-app_one-password app_two:change-me-app_two-password"

# ── Ingest API (telemetry gateway) ───────────────────────────────────────────
# Apps POST event batches here with an API key; the service buffers them on the
# internal Valkey ingest:events stream and drains them into each tenant's
# ClickHouse `events` table. Apps never get ClickHouse/Valkey credentials —
# only an API key (one key → one tenant). API keys are stored in the
# ingest.ingest_keys ClickHouse table; mint/revoke them via the admin endpoints.
#
# Bearer token guarding POST/GET/DELETE /v1/admin/keys. Generate a long random
# value (e.g. `openssl rand -hex 32`). Empty disables the admin endpoints.
INGEST_ADMIN_TOKEN="change-me-ingest-admin-token"
# Interface to bind the published ingest port to. Default 127.0.0.1. In
# production set to the host's private-overlay IP so apps on OTHER hosts can
# reach it:  INGEST_BIND="<your-overlay-ip>"
INGEST_BIND="127.0.0.1"
INGEST_EXT_PORT="46005"
# Log level for the ingest-api container.
INGEST_RUST_LOG="info"

# ── Monitoring (Prometheus + Grafana) — REMOVED for now ──────────────────────
# The prometheus + grafana services were removed from the stack. The vars below
# are unused until they are restored (see docker-compose.yml + git history).
# GRAFANA_ADMIN_PASSWORD="change-me-grafana-password"
# GRAFANA_ROOT_URL="http://127.0.0.1:3001"
# GRAFANA_EXT_PORT="3001"
# PROMETHEUS_EXT_PORT="9090"
