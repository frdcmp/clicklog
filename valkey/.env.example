# ════════════════════════════════════════════════════════════════════════════
# Shared Valkey broker — environment
# Copy to .env and fill in real secrets:  cp .env.example .env
# ════════════════════════════════════════════════════════════════════════════

# ── Bootstrap admin (the `default` ACL user; full access) ────────────────────
# Used by the healthcheck and for ops/migration. Keep secret.
VK_ADMIN_PASSWORD="change-me-admin-password"

# ── External exposure ────────────────────────────────────────────────────────
# A single high port for the Valkey endpoint (mapped to container 6379).
VK_EXT_PORT="46004"
# Interface to bind the published port to. Default 127.0.0.1 (localhost-only).
# In production set this to the host's private-overlay IP (e.g. the private overlay) so all
# stacks can reach it over the overlay:  VK_BIND="<your-overlay-ip>"
VK_BIND="127.0.0.1"

# ── Resources ────────────────────────────────────────────────────────────────
VK_MEM_LIMIT="1g"
VK_MAXMEMORY="768mb"      # keep below VK_MEM_LIMIT; noeviction policy
VK_CPUS="1"

# ── Tenants (name:password) ──────────────────────────────────────────────────
# Space-separated  name:password  pairs. One per service. `name` is BOTH the
# ACL username AND the mandatory key/channel prefix (service locked to
# ~name:* keys and &name:* channels). Add a pair here to onboard a service.
#   app_one   → MTG e-commerce
#   app_two  → app_two stack
VK_TENANTS="app_one:change-me-app_one-password app_two:change-me-app_two-password"
