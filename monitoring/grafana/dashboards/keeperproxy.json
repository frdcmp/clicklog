        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 * (1 - node_filesystem_avail_bytes{node=~\"$node\",mountpoint=\"/\"} / node_filesystem_size_bytes{node=~\"$node\",mountpoint=\"/\"})",
          "refId": "A",
          "range": true,
          "legendFormat": "{{node}}"
