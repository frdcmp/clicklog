# Where the Vite dev server proxies /v1 and /health.
# Local ingest-api (docker compose up on this host):
VITE_API_TARGET="http://localhost:46005"
# Or tunnel to <infra-host> PROD over the private overlay / SSH, e.g.:
#   ssh -L 46005:<overlay-ip>:46005 <infra-host>
# then keep the default above; or point straight at the overlay IP:
# VITE_API_TARGET="http://<overlay-ip>:46005"
